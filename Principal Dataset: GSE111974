gse <- getGEO("GSE111974", GSEMatrix = TRUE)
gse
exprSet <- gse[[1]]
exp_matrix<- exprs(exprSet)
dim(exp_matrix)
#genes 50599 / muestras 48

pheno <- pData(exprSet)
group <- ifelse(grepl("RIF", pheno$title), "RIF", "Control")
group<- factor(group)
table(group)
pheno$group <- group

